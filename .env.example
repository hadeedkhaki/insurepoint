ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Upstash Redis (state persistence across Vercel serverless invocations).
# Create a Redis store via Vercel Dashboard → Storage → Marketplace → Upstash.
# Vercel auto-populates these env vars on the project. Leave blank for local dev
# (the server will fall back to in-memory state).
KV_REST_API_URL=
KV_REST_API_TOKEN=
