{
  "_metadata": {
    "description": "ER tests, procedures, imaging, labs, medications, and E&M codes with realistic 2025-2026 costs. Designed to pair with the inSUREd mock insurance database.",
    "price_structure": {
      "chargemaster_price": "Hospital list price (what uninsured patients see on the bill)",
      "cash_price": "Self-pay rate, typically 40-60% off chargemaster",
      "insurance_negotiated_rate": "What most commercial insurers actually pay — roughly 40-50% of chargemaster",
      "medicare_rate": "Medicare fee schedule — typically 25-35% of chargemaster",
      "medicaid_rate": "Texas Medicaid rate — typically 15-25% of chargemaster"
    },
    "source": "Derived from published chargemaster data, CMS fee schedules, and public price transparency data (Turquoise Health, Taven Health, hospital MRFs).",
    "disclaimer": "All prices are representative averages for demo use. Real pricing varies by hospital, region, and payer contract."
  },
